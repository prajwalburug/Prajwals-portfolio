{
  "name": "Content Studio — Weekly Research Scan",
  "nodes": [
    {
      "id": "cron-trigger",
      "name": "Weekly Cron",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300],
      "parameters": {
        "rule": {
          "interval": [{"field": "cron", "expression": "0 7 * * 1"}]
        }
      }
    },
    {
      "id": "run-research",
      "name": "Run Research Scout",
      "type": "n8n-nodes-base.executeCommand",
      "position": [480, 300],
      "parameters": {
        "command": "python",
        "arguments": [
          "code/research_scout.py",
          "--brand",
          "awesome-hires",
          "--source",
          "all",
          "--dry-run"
        ]
      }
    },
    {
      "id": "slack-report",
      "name": "Slack Research Report",
      "type": "n8n-nodes-base.slack",
      "position": [720, 300],
      "parameters": {
        "channel": "content-studio",
        "text": "={{ 'Weekly Research Scan Complete\\nNew patterns found across LinkedIn, email, and competitor channels. Check whats-working.md for details.' }}",
        "as_user": true
      }
    },
    {
      "id": "email-report",
      "name": "Email Digest",
      "type": "n8n-nodes-base.emailSend",
      "position": [720, 500],
      "parameters": {
        "fromEmail": "research@content-studio.ai",
        "toEmail": "content-team@company.com",
        "subject": "Weekly Content Research Digest",
        "text": "={{ JSON.stringify($json, null, 2) }}"
      }
    }
  ],
  "connections": {
    "Weekly Cron": {"main": [[{"node": "Run Research Scout"}]]},
    "Run Research Scout": {"main": [[{"node": "Slack Research Report"}, {"node": "Email Digest"}]]}
  }
}
